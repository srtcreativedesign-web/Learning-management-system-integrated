// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

// A. Master Data (Sync from HRIS)

model UserShadow {
  id             String                   @id @default(uuid())
  hris_user_id   String                   @unique
  full_name      String
  email          String                   @unique
  join_date      DateTime?
  total_xp       Int                      @default(0)
  current_rank   String                   @default("Pemula")
  CourseProgress EmployeeCourseProgress[]
  QuizAttempts   EmployeeQuizAttempt[]
  XpAuditTrails  XpAuditTrail[]

  @@map("users_shadow")
}

model DivisionShadow {
  id               String            @id @default(uuid())
  hris_division_id String            @unique
  name             String
  Inspections      AuditInspection[]

  @@map("divisions_shadow")
}

model Outlet {
  id          String  @id @default(uuid())
  hris_id     Int     @unique // Mapping to organization.id from HRIS
  name        String
  address     String? @db.Text
  latitude    String?
  longitude   String?
  device_id   Int?    // From outlet_devices.id
  device_code String? // From outlet_devices.device_code
  device_name String? // From outlet_devices.device_name
  status      String  @default("active") // From outlet_devices.status

  @@map("outlets")
}

// B. LMS Tables

model Course {
  id             String                   @id @default(uuid())
  title          String
  description    String?
  thumbnail_url  String?
  reward_points  Int                      @default(0)
  due_date       DateTime?
  Materials      CourseMaterial[]
  CourseProgress EmployeeCourseProgress[]

  @@map("courses")
}

model CourseMaterial {
  id            String  @id @default(uuid())
  course_id     String
  type          String // 'pdf' | 'quiz'
  content_url   String? // Pre-signed URL or S3 key
  min_read_time Int? // in seconds

  Course Course @relation(fields: [course_id], references: [id], onDelete: Cascade)
  Quiz   Quiz?

  @@map("course_materials")
}

// Entitas Induk Kuis
model Quiz {
  id                      String  @id @default(uuid())
  course_material_id      String  @unique // Relasi 1-to-1 dengan CourseMaterial
  passing_score           Float // Nilai minimal kelulusan (misal 80.0)
  certificate_template_id String? // ID template sertifikat jika ada

  Material             CourseMaterial        @relation(fields: [course_material_id], references: [id], onDelete: Cascade)
  Questions            QuizQuestion[]
  Template             CertificateTemplate?  @relation(fields: [certificate_template_id], references: [id])
  EmployeeQuizAttempts EmployeeQuizAttempt[]

  @@map("quizzes")
}

// Bank Soal
model QuizQuestion {
  id            String @id @default(uuid())
  quiz_id       String
  question_text String @db.Text
  type          String @default("MULTIPLE_CHOICE") // MULTIPLE_CHOICE, MULTIPLE_ANSWER, TRUE_FALSE

  Quiz    Quiz         @relation(fields: [quiz_id], references: [id], onDelete: Cascade)
  Options QuizOption[]

  @@map("quiz_questions")
}

// Pilihan Jawaban
model QuizOption {
  id          String  @id @default(uuid())
  question_id String
  option_text String
  is_correct  Boolean // Kunci jawaban

  Question QuizQuestion @relation(fields: [question_id], references: [id], onDelete: Cascade)

  @@map("quiz_options")
}

// Template Sertifikat
model CertificateTemplate {
  id              String @id @default(uuid())
  name            String
  bg_image_url    String // Latar belakang sertifikat
  name_pos_x      Float // Koordinat X untuk nama peserta
  name_pos_y      Float // Koordinat Y untuk nama peserta
  name_font_size  Int    @default(32)
  name_font_color String @default("#000000")

  Quizzes Quiz[]

  @@map("certificate_templates")
}

model EmployeeCourseProgress {
  id        String @id @default(uuid())
  user_id   String
  course_id String
  status    String // 'enrolled' | 'completed'

  User   UserShadow @relation(fields: [user_id], references: [id], onDelete: Cascade)
  Course Course     @relation(fields: [course_id], references: [id], onDelete: Cascade)

  @@map("employee_course_progress")
}

model EmployeeQuizAttempt {
  id        String  @id @default(uuid())
  user_id   String
  quiz_id    String
  score      Float
  is_passed  Boolean
  xp_awarded Int     @default(0)
  answers_detail Json?
  created_at DateTime @default(now())

  User UserShadow @relation(fields: [user_id], references: [id], onDelete: Cascade)
  Quiz Quiz       @relation(fields: [quiz_id], references: [id], onDelete: Cascade)

  @@map("employee_quiz_attempts")
}

// C. Audit Tables

model AuditTemplate {
  id         String           @id @default(uuid())
  title      String
  version    Int
  Checklists AuditChecklist[]

  @@map("audit_templates")
}

model AuditChecklist {
  id            String         @id @default(uuid())
  template_id   String
  question_text String
  Template      AuditTemplate  @relation(fields: [template_id], references: [id], onDelete: Cascade)
  Findings      AuditFinding[]

  @@map("audit_checklists")
}

model AuditInspection {
  id          String         @id @default(uuid())
  auditor_id  String // bisa referensi ke UserShadow jika auditor ada di sana
  division_id String
  status      String // 'draft' | 'submitted' | 'approved'
  Division    DivisionShadow @relation(fields: [division_id], references: [id])
  Findings    AuditFinding[]

  @@map("audit_inspections")
}

model AuditCategory {
  id         String @id @default(uuid())
  name       String
  sort_order Int    @default(0)

  checklists AuditChecklistPoint[]

  @@map("audit_categories")
}

model AuditChecklistPoint {
  id          String @id @default(uuid())
  category_id String
  question    String
  sort_order  Int    @default(0)

  category AuditCategory @relation(fields: [category_id], references: [id], onDelete: Cascade)

  @@map("audit_checklist_points")
}

model AuditFinding {
  id               String   @id @default(uuid())
  inspection_id    String
  checklist_id     String
  notes            String?
  photo_path       String? // local & remote S3 URL
  is_compliant     Boolean
  sync_status      String   @default("pending") // pending/syncing/synced/failed
  last_modified_at DateTime @default(now()) @updatedAt

  Inspection AuditInspection @relation(fields: [inspection_id], references: [id], onDelete: Cascade)
  Checklist  AuditChecklist  @relation(fields: [checklist_id], references: [id], onDelete: Cascade)

  @@map("audit_findings")
}

// D. SOP Management

model SopDocument {
  id          String      @id @default(uuid())
  title       String
  category    String      // 'HEAD_OFFICE' | 'OPERASIONAL'
  source_pdf  String?     // File PDF asli yang diunggah
  created_at  DateTime    @default(now())
  updated_at  DateTime    @updatedAt
  
  Points      SopPoint[]

  @@map("sop_documents")
}

model SopPoint {
  id          String      @id @default(uuid())
  sop_id      String
  order_num   Int
  title       String      @db.Text
  description String?     @db.Text
  
  Document    SopDocument @relation(fields: [sop_id], references: [id], onDelete: Cascade)

  @@map("sop_points")
}

// E. Gamification Audit
model XpAuditTrail {
  id           String     @id @default(uuid())
  user_id      String
  old_xp       Int
  new_xp       Int
  reason       String?    @db.Text
  created_at   DateTime   @default(now())

  User         UserShadow @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("xp_audit_trails")
}

