    "chart.js": "^4.5.1",
    "gsap": "^3.15.0",
    "pinia": "^3.0.4",
    "primeicons": "^7.0.0",
    "primevue": "^4.5.5",
    "vue": "^3.5.38",
    "vue-chartjs": "^5.3.4",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.2",
    "@tailwindcss/vite": "^4.3.2",
    "@tsconfig/node24": "^24.0.4",
